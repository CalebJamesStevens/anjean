{
  "configurations": [
    {
      "name": "Mac",
      "compilerPath": "/usr/bin/clang++",
      "compileCommands": "${workspaceFolder}/build/compile_commands.json",
      "includePath": [
        "${workspaceFolder}/src",
        "${workspaceFolder}/external/metal-cpp",
        "/opt/homebrew/include",
        "/opt/homebrew/opt/sdl3/include"
      ],
      "defines": [
        "ANJEAN_PLATFORM_MACOS=1",
        "ANJEAN_RENDERER_METAL=1"
      ],
      "cStandard": "c17",
      "cppStandard": "c++17",
      "intelliSenseMode": "macos-clang-arm64",
      "macFrameworkPath": [
        "/System/Library/Frameworks",
        "/Library/Frameworks"
      ],
      "browse": {
        "path": [
          "${workspaceFolder}/src",
          "${workspaceFolder}/external/metal-cpp",
          "/opt/homebrew/include",
          "/opt/homebrew/opt/sdl3/include"
        ]
      }
    }
  ],
  "version": 4
}